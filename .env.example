TIINGO_API_KEY=your_tiingo_api_key_here
NEWS_API_KEY=your_newsapi_key_here

# ntfy server (default: public ntfy.sh, use your own for privacy)
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=trading-copilot

# Webhook base URL (where ntfy will call back for Enter/Skip actions)
WEBHOOK_BASE_URL=http://your-server-ip:8000

# Database paths
DUCKDB_PATH=data/market.duckdb
SQLITE_PATH=data/positions.db
